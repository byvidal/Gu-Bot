<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <link rel="stylesheet" href="/public/admin.css">
</head>
<body>

<div class="login-box">
    <h1>Admin Login</h1>

    <% if(error) { %>
        <p><%= error %></p>
    <% } %>

    <form method="POST">
        <input name="username" placeholder="Usuario">
        <input type="password" name="password" placeholder="Contraseña">

        <button type="submit">Entrar</button>
    </form>
</div>

</body>
</html>